# Template — DO NOT commit a filled-in version.
#
# Apply once, out-of-band (NOT via ArgoCD, same pattern as fishky-dashboard-secrets):
#   1. Fill in your Resend credentials below
#   2. Apply:  kubectl apply -f secret.yaml
#   3. Verify: kubectl -n fishky-front get secret fishky-front-secrets
#
# These are read at RUNTIME by /api/subscribe (newsletter endpoint).
apiVersion: v1
kind: Secret
metadata:
  name: fishky-front-secrets
  namespace: fishky-front
type: Opaque
stringData:
  RESEND_API_KEY: "re_CHANGEME"
  RESEND_AUDIENCE_ID: "CHANGEME"
