# Template — DO NOT commit a filled-in version.
#
# Apply once, out-of-band (NOT via ArgoCD, same pattern as fishky-secrets):
#   1. Provision the readonly DB role on the LXC PG host:
#        ssh root@10.0.20.51
#        READONLY_PASSWORD=...generate... bash provision-readonly-user.sh
#      (script lives in fishky/dashboard/scripts/)
#   2. Fill DATABASE_URL below and apply:
#        kubectl apply -f secret.yaml
#   3. Verify:
#        kubectl -n fishky get secret fishky-dashboard-secrets
apiVersion: v1
kind: Secret
metadata:
  name: fishky-dashboard-secrets
  namespace: fishky
type: Opaque
stringData:
  # postgresql://<readonly_user>:<password>@10.0.20.51:5432/fishky
  DATABASE_URL: "postgresql://fishky_readonly:CHANGEME@10.0.20.51:5432/fishky"
