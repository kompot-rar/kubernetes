# Template — DO NOT commit a filled-in version.
#
# Create the krakweek namespace first:
#   kubectl create namespace krakweek
#
# Copy the GHCR secret from the fishky namespace:
#   kubectl get secret ghcr-secret -n fishky -o yaml | sed 's/namespace: fishky/namespace: krakweek/' | kubectl apply -f -
#
# Generate a strong password:
#   openssl rand -hex 16
#
# Fill in the secrets below and apply:
#   kubectl apply -f secret.yaml
#
# Verify:
#   kubectl -n krakweek get secret krakweek-secrets
apiVersion: v1
kind: Secret
metadata:
  name: krakweek-secrets
  namespace: krakweek
type: Opaque
stringData:
  POSTGRES_PASSWORD: "CHANGEME_STRONG_PASSWORD"
  DATABASE_URL: "postgres://postgres:CHANGEME_STRONG_PASSWORD@postgres:5432/krakweek?sslmode=disable"
